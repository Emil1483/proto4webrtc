# Single env for the whole example (server + robot). Copy to .env and fill in.
# Auto-sourced in the devcontainer; the robot's docker compose reads it too.
# The example enforces auth: the server rejects every signaling connection
# until AUTH_PASSWORD and ROBOT_TOKEN are set.

# Browser login password (shared, single-user). Log in on the homepage to
# become admin and view protected streams (camera, pointcloud).
AUTH_PASSWORD=

# HMAC key for signing session cookies. Optional in dev (derived from
# AUTH_PASSWORD if unset); set explicitly in production.
AUTH_SECRET=

# Shared robot secret. The robot sends it as "Authorization: Bearer <token>";
# the server matches it to grant Role.ROBOT.
ROBOT_TOKEN=

