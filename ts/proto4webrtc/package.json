{
  "name": "proto4webrtc",
  "version": "1.5.0",
  "description": "mediasoup runtime for proto4webrtc-annotated protofiles: SFU (signaling, transports, in-process data-stream subscriptions) and browser consumer client",
  "license": "MIT",
  "author": "Emil Djupvik",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Emil1483/proto4webrtc.git",
    "directory": "ts/proto4webrtc"
  },
  "keywords": [
    "mediasoup",
    "webrtc",
    "sfu",
    "protobuf"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json || (npm install && tsc -p tsconfig.json)",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.1",
    "mediasoup": "^3.21.0",
    "mediasoup-client": "^3.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "ws": "^8.21.0"
  }
}
